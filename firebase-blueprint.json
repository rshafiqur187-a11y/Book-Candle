{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A book product in the store",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "price": { "type": "number" },
        "discount": { "type": "number" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "mediaType": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["title", "price", "description", "image"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "location": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "senderNumber": { "type": "string" },
        "transactionId": { "type": "string" },
        "items": { "type": "array" },
        "subtotal": { "type": "number" },
        "deliveryCharge": { "type": "number" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "phone", "address", "location", "paymentMethod", "items", "total", "status"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Products collection"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Orders collection"
    }
  }
}
